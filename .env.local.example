# Stripe — get keys from https://dashboard.stripe.com/apikeys
# TEST MODE: use sk_test_ / pk_test_ keys
# LIVE MODE: use sk_live_ / pk_live_ keys (real money to your Stripe account)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Test card for Card checkout: 4242 4242 4242 4242 | any future expiry | any CVC
# Enable PayPal in Stripe Dashboard → Settings → Payment methods for PayPal flow

# Webhook — create at https://dashboard.stripe.com/webhooks
# Endpoint URL: https://yourdomain.com/api/webhooks/stripe
# Event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Site URL (required for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
